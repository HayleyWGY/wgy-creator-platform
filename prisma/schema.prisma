generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Creator {
  id                  String                @id @default(cuid())
  email               String                @unique
  passwordHash        String
  firstName           String
  lastName            String
  bio                 String?
  profileImageUrl     String?
  instagramHandle     String?
  tiktokHandle        String?
  youtubeUrl          String?
  otherSocialLinks    Json?
  addressLine1        String?
  addressLine2        String?
  city                String?
  postcode            String?
  country             String?
  contentNiches       String[]              @default([])
  // The four fields below are encrypted at rest (AES-256-GCM) via
  // lib/field-crypto.ts — dateOfBirth is a "YYYY-MM-DD" string inside the
  // ciphertext, not a native date. Never query or render them raw.
  dateOfBirth         String?
  address             String?               @db.Text
  contactNumber       String?
  gender              String?
  stripeCustomerId    String?
  stripeSubId         String?
  membershipStatus    String                @default("active")
  // Stamped whenever membershipStatus flips to cancelled (kept on
  // reactivation so monthly-cancellation analytics retain history)
  cancelledAt         DateTime?
  membershipType      String                @default("paid")
  isAdmin             Boolean               @default(false)
  isClient            Boolean               @default(false)
  joinedAt            DateTime              @default(now())
  lastSeenAt          DateTime              @default(now())
  // Set the first time the creator taps Apply on any opportunity —
  // powers the "apply to your first opportunity" checklist item
  firstApplyAt        DateTime?
  // Login brute-force protection — see lib/auth.ts authorize()
  failedLoginAttempts Int                   @default(0)
  lockedUntil         DateTime?
  // Null means the account has never had a password chosen BY ITS OWNER: it
  // was created by an admin with an unusable random hash and is waiting on a
  // setup link. lastSeenAt cannot express this — it defaults to now().
  passwordSetAt       DateTime?
  tags                CreatorTag[]
  posts               Post[]
  comments            Comment[]
  likes               Like[]
  notifications       Notification[]
  creatorPosts        CreatorPost[]
  creatorPostComments CreatorPostComment[]
  contentComments     ContentComment[]
  creatorPostLikes    CreatorPostLike[]
  chatMessages        ChatMessage[]
  chatRoomReads       ChatRoomRead[]
  applications        CampaignApplication[]
  dmThread            DmThread?
  dmMessagesSent      DmMessage[]           @relation("DmSender")
  auditLogs           AuditLog[]            @relation("AuditActor")
  accountTokens       AccountToken[]

  // Member segmentation at scale: mass-DM audiences, analytics, onboarding
  // drip and the admin list all filter by membershipStatus + an activity/
  // date column. Without these each query scans the whole members table.
  @@index([membershipStatus, lastSeenAt]) // active / inactive segments
  @@index([membershipStatus, joinedAt]) // new members, onboarding, list order
  @@index([membershipStatus, firstApplyAt]) // "not applied yet" segment
  @@index([cancelledAt]) // cancellation analytics
}

model Section {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  group       String
  iconEmoji   String?
  sortOrder   Int     @default(0)
  isVisible   Boolean @default(true)
  sectionType String  @default("post_feed")
  posts       Post[]
}

model Post {
  id                     String    @id @default(cuid())
  sectionId              String
  section                Section   @relation(fields: [sectionId], references: [id])
  authorId               String
  author                 Creator   @relation(fields: [authorId], references: [id])
  title                  String
  body                   String
  coverImageUrl          String?
  brandName              String?
  applyLinkUrl           String?
  postType               String    @default("campaign")
  status                 String    @default("draft")
  scheduledAt            DateTime?
  applyClicks            Int       @default(0)
  publishedAt            DateTime?
  createdAt              DateTime  @default(now())
  likesCount             Int       @default(0)
  commentsCount          Int       @default(0)
  isPinned               Boolean   @default(false)
  eventDate              DateTime?
  eventLocation          String?
  eventPrice             Int?
  slug                   String?   @unique
  brandDescription       String?
  brandWebsite           String?
  brandInstagram         String?
  brandTikTok            String?
  brandLogoUrl           String?
  opportunityDescription String?
  deliverables           Json?
  spotsRemaining         Int?
  campaignType           String?
  paymentAmount          String?
  paymentTerms           String?
  eventTime              String?
  comments               Comment[]
  likes                  Like[]

  // Campaign lists filter by section + status and order by publish date
  @@index([status, publishedAt])
  @@index([sectionId])
  @@index([authorId])
}

model Tag {
  id          String       @id @default(cuid())
  name        String
  colour      String       @default("#e4dcd1")
  createdById String
  createdAt   DateTime     @default(now())
  creators    CreatorTag[]
}

model CreatorTag {
  creatorId          String
  creator            Creator  @relation(fields: [creatorId], references: [id])
  tagId              String
  tag                Tag      @relation(fields: [tagId], references: [id])
  assignedAt         DateTime @default(now())
  assignedById       String
  isVisibleToCreator Boolean  @default(true)

  @@id([creatorId, tagId])
  // Broadcasting to everyone with a given tag
  @@index([tagId])
}

model Comment {
  id        String    @id @default(cuid())
  postId    String
  post      Post      @relation(fields: [postId], references: [id])
  authorId  String
  author    Creator   @relation(fields: [authorId], references: [id])
  body      String
  parentId  String?
  parent    Comment?  @relation("CampaignCommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CampaignCommentReplies")
  createdAt DateTime  @default(now())
  isDeleted Boolean   @default(false)

  @@index([postId])
  @@index([parentId])
  @@index([authorId])
}

// Per-admin watermark for the Engagement feed — everything newer than
// engagementSeenAt counts towards the sidebar badge
model AdminRead {
  adminId          String   @id
  engagementSeenAt DateTime @default(now())
}

model Like {
  creatorId String
  creator   Creator  @relation(fields: [creatorId], references: [id])
  postId    String
  post      Post     @relation(fields: [postId], references: [id])
  createdAt DateTime @default(now())

  @@id([creatorId, postId])
  @@index([postId])
}

model Notification {
  id          String   @id @default(cuid())
  creatorId   String
  creator     Creator  @relation(fields: [creatorId], references: [id])
  type        String
  title       String
  description String
  referenceId String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  // Fetching a creator's notifications, newest first, and unread counts
  @@index([creatorId, createdAt])
  @@index([creatorId, isRead])
}

model PostContent {
  id                  String           @id @default(cuid())
  title               String
  contentType         String
  body                String?
  pdfUrl              String?
  editableTemplateUrl String?
  videoEmbedUrl       String?
  videoTranscript     String?
  thumbnailUrl        String?
  bannerImageUrl      String?
  section             String
  categories          String[]
  status              String           @default("draft")
  scheduledAt         DateTime?
  publishedAt         DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  authorId            String
  likesCount          Int              @default(0)
  commentsCount       Int              @default(0)
  sortOrder           Int              @default(0)
  readingTimeMinutes  Int?
  comments            ContentComment[]

  // Learning Lounge lists filter by section + status
  @@index([section, status])
  @@index([status, publishedAt])
}

model MessageTemplate {
  id           String                  @id @default(cuid())
  sequenceName String
  dayOffset    Int
  subject      String
  body         String
  isActive     Boolean                 @default(true)
  sortOrder    Int                     @default(0)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  sentLogs     OnboardingMessageSent[]
}

model CreatorPost {
  id            String               @id @default(cuid())
  authorId      String
  author        Creator              @relation(fields: [authorId], references: [id])
  body          String               @db.Text
  imageUrl      String?
  likesCount    Int                  @default(0)
  commentsCount Int                  @default(0)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  isDeleted     Boolean              @default(false)
  comments      CreatorPostComment[]
  likes         CreatorPostLike[]

  // Community feed: newest non-deleted posts
  @@index([isDeleted, createdAt])
  @@index([authorId])
}

model CreatorPostComment {
  id        String               @id @default(cuid())
  postId    String
  post      CreatorPost          @relation(fields: [postId], references: [id])
  authorId  String
  author    Creator              @relation(fields: [authorId], references: [id])
  body      String               @db.Text
  parentId  String?
  parent    CreatorPostComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   CreatorPostComment[] @relation("CommentReplies")
  createdAt DateTime             @default(now())
  isDeleted Boolean              @default(false)

  @@index([postId])
  @@index([parentId])
}

model CreatorPostLike {
  id        String      @id @default(cuid())
  postId    String
  post      CreatorPost @relation(fields: [postId], references: [id])
  creatorId String
  creator   Creator     @relation(fields: [creatorId], references: [id])
  createdAt DateTime    @default(now())

  @@unique([postId, creatorId])
}

model OnboardingMessageSent {
  id              String          @id @default(cuid())
  creatorId       String
  templateId      String
  template        MessageTemplate @relation(fields: [templateId], references: [id])
  sentAt          DateTime        @default(now())
  streamMessageId String?
}

model ChatRoom {
  id              String         @id @default(cuid())
  slug            String         @unique
  name            String
  emoji           String
  description     String
  isActive        Boolean        @default(true)
  sortOrder       Int            @default(0)
  pinnedMessageId String?
  pinnedMessage   ChatMessage?   @relation("PinnedMessage", fields: [pinnedMessageId], references: [id])
  messages        ChatMessage[]  @relation("RoomMessages")
  reads           ChatRoomRead[]
  createdAt       DateTime       @default(now())
}

model ChatMessage {
  id           String     @id @default(cuid())
  roomId       String
  room         ChatRoom   @relation("RoomMessages", fields: [roomId], references: [id])
  pinnedInRoom ChatRoom[] @relation("PinnedMessage")
  authorId     String
  author       Creator    @relation(fields: [authorId], references: [id])
  body         String     @db.Text
  imageUrl     String?
  isDeleted    Boolean    @default(false)
  deletedAt    DateTime?
  createdAt    DateTime   @default(now())

  // Loading a room's messages in order
  @@index([roomId, createdAt])
  @@index([authorId])
}

model DmThread {
  id        String      @id @default(cuid())
  creatorId String      @unique
  creator   Creator     @relation(fields: [creatorId], references: [id])
  messages  DmMessage[]
  isPinned  Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model DmMessage {
  id        String    @id @default(cuid())
  threadId  String
  thread    DmThread  @relation(fields: [threadId], references: [id])
  senderId  String
  sender    Creator   @relation("DmSender", fields: [senderId], references: [id])
  body      String    @db.Text
  imageUrl  String?
  isRead    Boolean   @default(false)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  // Loading a thread's messages, and admin unread counts
  @@index([threadId, createdAt])
  @@index([senderId])
}

// Comments on Learning Lounge content (blogs, videos, workbooks)
model ContentComment {
  id        String      @id @default(cuid())
  contentId String
  content   PostContent @relation(fields: [contentId], references: [id], onDelete: Cascade)
  authorId  String
  author    Creator     @relation(fields: [authorId], references: [id])
  body      String      @db.Text
  createdAt DateTime    @default(now())

  @@index([contentId])
}

// Per-creator read state for community chat rooms — powers unread badges
model ChatRoomRead {
  creatorId  String
  creator    Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  roomId     String
  room       ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  lastReadAt DateTime @default(now())

  @@id([creatorId, roomId])
}

// Trail of significant admin actions — shown in Admin Settings
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actor      Creator  @relation("AuditActor", fields: [actorId], references: [id])
  action     String
  detail     String?  @db.Text
  targetType String?
  targetId   String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

// A completed campaign application, recorded when a creator submits the
// portal application form via the secure handoff (portal calls
// /api/record-application with a signed receipt token). Campaign details
// are stored as plain strings from the portal — deliberately decoupled
// from Post, since portal campaigns aren't the same records as app posts.
model CampaignApplication {
  id           String   @id @default(cuid())
  creatorId    String
  creator      Creator  @relation(fields: [creatorId], references: [id])
  campaignName String
  campaignSlug String?
  appliedAt    DateTime @default(now())

  @@index([creatorId, appliedAt])
}

/// Single-use, expiring tokens for account actions that must work without an
/// existing password: admin invite setup and (later) password reset.
///
/// Only a SHA-256 hash of the token is stored, so a database leak yields
/// nothing usable — the raw value exists only in the link handed to the
/// recipient. Rows are kept after use rather than deleted, so the audit trail
/// shows when a link was redeemed.
model AccountToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  purpose   String // 'admin_setup' | 'password_reset'
  creatorId String
  creator   Creator   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([creatorId, purpose])
}
