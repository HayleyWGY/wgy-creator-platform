generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Creator {
  id                String         @id @default(cuid())
  email             String         @unique
  passwordHash      String
  firstName         String
  lastName          String
  bio               String?
  profileImageUrl   String?
  instagramHandle   String?
  tiktokHandle      String?
  youtubeUrl        String?
  otherSocialLinks  Json?
  addressLine1      String?
  addressLine2      String?
  city              String?
  postcode          String?
  country           String?
  contentNiches     String[]       @default([])
  dateOfBirth       DateTime?
  address           String?        @db.Text
  contactNumber     String?
  gender            String?
  stripeCustomerId  String?
  stripeSubId       String?
  membershipStatus  String         @default("active")
  membershipType    String         @default("paid")
  isAdmin           Boolean        @default(false)
  isClient          Boolean        @default(false)
  joinedAt          DateTime       @default(now())
  lastSeenAt        DateTime       @default(now())
  tags                CreatorTag[]
  posts               Post[]
  comments            Comment[]
  likes               Like[]
  notifications       Notification[]
  creatorPosts        CreatorPost[]
  creatorPostComments CreatorPostComment[]
  creatorPostLikes    CreatorPostLike[]
  chatMessages        ChatMessage[]
  dmThread            DmThread?
  dmMessagesSent      DmMessage[]         @relation("DmSender")
}

model Section {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  group       String
  iconEmoji   String?
  sortOrder   Int     @default(0)
  isVisible   Boolean @default(true)
  sectionType String  @default("post_feed")
  posts       Post[]
}

model Post {
  id            String    @id @default(cuid())
  sectionId     String
  section       Section   @relation(fields: [sectionId], references: [id])
  authorId      String
  author        Creator   @relation(fields: [authorId], references: [id])
  title         String
  body          String
  coverImageUrl String?
  brandName     String?
  applyLinkUrl  String?
  postType      String    @default("campaign")
  status        String    @default("draft")
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  likesCount    Int       @default(0)
  commentsCount Int       @default(0)
  isPinned               Boolean   @default(false)
  eventDate              DateTime?
  eventLocation          String?
  eventPrice             Int?
  slug                   String?   @unique
  brandDescription       String?
  brandWebsite           String?
  brandInstagram         String?
  brandTikTok            String?
  brandLogoUrl           String?
  opportunityDescription String?
  deliverables           Json?
  spotsRemaining         Int?
  campaignType           String?
  paymentAmount          String?
  paymentTerms           String?
  eventTime              String?
  comments               Comment[]
  likes                  Like[]
}

model Tag {
  id          String       @id @default(cuid())
  name        String
  colour      String       @default("#e4dcd1")
  createdById String
  createdAt   DateTime     @default(now())
  creators    CreatorTag[]
}

model CreatorTag {
  creatorId          String
  creator            Creator  @relation(fields: [creatorId], references: [id])
  tagId              String
  tag                Tag      @relation(fields: [tagId], references: [id])
  assignedAt         DateTime @default(now())
  assignedById       String
  isVisibleToCreator Boolean  @default(true)

  @@id([creatorId, tagId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id])
  authorId  String
  author    Creator  @relation(fields: [authorId], references: [id])
  body      String
  createdAt DateTime @default(now())
  isDeleted Boolean  @default(false)
}

model Like {
  creatorId String
  creator   Creator  @relation(fields: [creatorId], references: [id])
  postId    String
  post      Post     @relation(fields: [postId], references: [id])
  createdAt DateTime @default(now())

  @@id([creatorId, postId])
}

model Notification {
  id          String   @id @default(cuid())
  creatorId   String
  creator     Creator  @relation(fields: [creatorId], references: [id])
  type        String
  title       String
  description String
  referenceId String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model PostContent {
  id                   String    @id @default(cuid())
  title                String
  contentType          String
  body                 String?
  pdfUrl               String?
  editableTemplateUrl  String?
  videoEmbedUrl        String?
  videoTranscript      String?
  thumbnailUrl         String?
  bannerImageUrl       String?
  section              String
  categories           String[]
  status               String    @default("draft")
  scheduledAt          DateTime?
  publishedAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  authorId             String
  likesCount           Int       @default(0)
  commentsCount        Int       @default(0)
  sortOrder            Int       @default(0)
  readingTimeMinutes   Int?
}

model MessageTemplate {
  id           String    @id @default(cuid())
  sequenceName String
  dayOffset    Int
  subject      String
  body         String
  isActive     Boolean   @default(true)
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sentLogs     OnboardingMessageSent[]
}

model CreatorPost {
  id            String               @id @default(cuid())
  authorId      String
  author        Creator              @relation(fields: [authorId], references: [id])
  body          String               @db.Text
  imageUrl      String?
  likesCount    Int                  @default(0)
  commentsCount Int                  @default(0)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  isDeleted     Boolean              @default(false)
  comments      CreatorPostComment[]
  likes         CreatorPostLike[]
}

model CreatorPostComment {
  id        String               @id @default(cuid())
  postId    String
  post      CreatorPost          @relation(fields: [postId], references: [id])
  authorId  String
  author    Creator              @relation(fields: [authorId], references: [id])
  body      String               @db.Text
  parentId  String?
  parent    CreatorPostComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   CreatorPostComment[] @relation("CommentReplies")
  createdAt DateTime             @default(now())
  isDeleted Boolean              @default(false)
}

model CreatorPostLike {
  id        String      @id @default(cuid())
  postId    String
  post      CreatorPost @relation(fields: [postId], references: [id])
  creatorId String
  creator   Creator     @relation(fields: [creatorId], references: [id])
  createdAt DateTime    @default(now())

  @@unique([postId, creatorId])
}

model OnboardingMessageSent {
  id              String          @id @default(cuid())
  creatorId       String
  templateId      String
  template        MessageTemplate @relation(fields: [templateId], references: [id])
  sentAt          DateTime        @default(now())
  streamMessageId String?
}

model ChatRoom {
  id              String        @id @default(cuid())
  slug            String        @unique
  name            String
  emoji           String
  description     String
  isActive        Boolean       @default(true)
  sortOrder       Int           @default(0)
  pinnedMessageId String?
  pinnedMessage   ChatMessage?  @relation("PinnedMessage", fields: [pinnedMessageId], references: [id])
  messages        ChatMessage[] @relation("RoomMessages")
  createdAt       DateTime      @default(now())
}

model ChatMessage {
  id           String     @id @default(cuid())
  roomId       String
  room         ChatRoom   @relation("RoomMessages", fields: [roomId], references: [id])
  pinnedInRoom ChatRoom[] @relation("PinnedMessage")
  authorId     String
  author       Creator    @relation(fields: [authorId], references: [id])
  body         String     @db.Text
  imageUrl     String?
  isDeleted    Boolean    @default(false)
  deletedAt    DateTime?
  createdAt    DateTime   @default(now())
}

model DmThread {
  id        String      @id @default(cuid())
  creatorId String      @unique
  creator   Creator     @relation(fields: [creatorId], references: [id])
  messages  DmMessage[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model DmMessage {
  id        String    @id @default(cuid())
  threadId  String
  thread    DmThread  @relation(fields: [threadId], references: [id])
  senderId  String
  sender    Creator   @relation("DmSender", fields: [senderId], references: [id])
  body      String    @db.Text
  imageUrl  String?
  isRead    Boolean   @default(false)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
}
